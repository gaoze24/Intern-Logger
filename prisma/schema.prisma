// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatusType {
  WISHLIST
  PREPARING
  APPLIED
  ONLINE_ASSESSMENT
  RECRUITER_SCREEN
  TECHNICAL_INTERVIEW
  BEHAVIORAL_INTERVIEW
  FINAL_ROUND
  OFFER
  REJECTED
  WITHDRAWN
  ARCHIVED
  CUSTOM
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
  UNKNOWN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  DREAM
}

enum Source {
  LINKEDIN
  COMPANY_WEBSITE
  REFERRAL
  CAREER_FAIR
  RECRUITER
  UNIVERSITY_PORTAL
  EMAIL
  OTHER
}

enum InternshipSeason {
  SUMMER
  WINTER
  SPRING
  FALL
  OFF_CYCLE
}

enum InterviewType {
  OA
  PHONE_SCREEN
  HR_INTERVIEW
  TECHNICAL_INTERVIEW
  BEHAVIORAL_INTERVIEW
  CASE_INTERVIEW
  FINAL_ROUND
  TAKE_HOME
  GROUP_INTERVIEW
  OTHER
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  CANCELED
}

enum DocumentType {
  RESUME
  COVER_LETTER
  TRANSCRIPT
  PORTFOLIO
  GITHUB
  WEBSITE
  WRITING_SAMPLE
  OTHER
}

enum RelationshipType {
  RECRUITER
  ALUMNI
  REFERRAL
  INTERVIEWER
  HIRING_MANAGER
  EMPLOYEE
  FRIEND
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderType {
  APPLICATION_DEADLINE
  OA_DEADLINE
  INTERVIEW
  FOLLOW_UP
  OFFER_DECISION
  TASK_DUE
}

enum ActivityEntityType {
  APPLICATION
  STATUS
  INTERVIEW
  TASK
  CONTACT
  DOCUMENT
  TIMELINE
  NOTE
  REMINDER
}

enum TimelineEventType {
  DISCOVERED
  PREPARATION_STARTED
  APPLIED
  OA_RECEIVED
  OA_SUBMITTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
  FOLLOW_UP_SENT
  STATUS_CHANGED
  NOTE_ADDED
}

model User {
  id              String              @id @default(cuid())
  name            String?
  email           String              @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  accounts        Account[]
  sessions        Session[]
  statuses        ApplicationStatus[]
  tags            Tag[]
  applications    Application[]
  interviews      Interview[]
  tasks           Task[]
  contacts        Contact[]
  documents       Document[]
  timelineEvents  TimelineEvent[]
  activityLogs    ActivityLog[]
  reminders       Reminder[]
  settings        UserSettings?
}

model Application {
  id                String                  @id @default(cuid())
  userId            String
  companyName       String
  roleTitle         String
  department        String?
  location          String?
  country           String?
  workMode          WorkMode                @default(UNKNOWN)
  status            ApplicationStatusType   @default(WISHLIST)
  customStatusId    String?
  priority          Priority                @default(MEDIUM)
  source            Source                  @default(OTHER)
  applicationUrl    String?
  jobPostingUrl     String?
  deadline          DateTime?
  appliedDate       DateTime?
  discoveredDate    DateTime?
  season            InternshipSeason?
  applicationYear   Int?
  compensation      String?
  visaSponsorship   Boolean?
  referralUsed      Boolean                 @default(false)
  jobDescription    String?
  notes             String?
  archived          Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  customStatus      ApplicationStatus?      @relation(fields: [customStatusId], references: [id], onDelete: SetNull)
  interviews        Interview[]
  tasks             Task[]
  timelineEvents    TimelineEvent[]
  activities        ActivityLog[]
  reminders         Reminder[]
  tags              ApplicationTag[]
  contacts          ApplicationContact[]
  documents         ApplicationDocument[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
  @@index([appliedDate])
  @@index([archived])
  @@index([userId, archived, status])
  @@index([userId, status])
  @@index([userId, archived])
  @@index([userId, companyName, roleTitle])
  @@index([userId, companyName])
  @@index([userId, roleTitle])
  @@index([userId, deadline])
  @@index([userId, updatedAt])
  @@index([updatedAt])
}

model ApplicationStatus {
  id             String        @id @default(cuid())
  userId         String
  name           String
  color          String        @default("#64748b")
  order          Int
  isFinal        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications   Application[]

  @@unique([userId, name])
  @@index([userId, order])
}

model Tag {
  id             String          @id @default(cuid())
  userId         String
  name           String
  color          String          @default("#a855f7")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications   ApplicationTag[]

  @@unique([userId, name])
}

model ApplicationTag {
  applicationId  String
  tagId          String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tag            Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([applicationId, tagId])
}

model Interview {
  id                String            @id @default(cuid())
  userId            String
  applicationId     String
  title             String
  type              InterviewType
  scheduledAt       DateTime
  durationMinutes   Int?
  location          String?
  meetingLink       String?
  interviewerName   String?
  interviewerEmail  String?
  preparationNotes  String?
  questionsAsked    String?
  reflection        String?
  outcome           InterviewOutcome  @default(PENDING)
  followUpRequired  Boolean           @default(false)
  thankYouSent      Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  application       Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reminders         Reminder[]

  @@index([userId])
  @@index([applicationId])
  @@index([scheduledAt])
  @@index([userId, scheduledAt])
}

model Task {
  id              String        @id @default(cuid())
  userId          String
  applicationId   String?
  title           String
  description     String?
  dueDate         DateTime?
  priority        TaskPriority  @default(MEDIUM)
  completed       Boolean       @default(false)
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  reminders       Reminder[]

  @@index([userId])
  @@index([applicationId])
  @@index([dueDate])
  @@index([completed])
  @@index([userId, dueDate])
  @@index([userId, completed])
  @@index([userId, completed, dueDate])
}

model Contact {
  id               String              @id @default(cuid())
  userId           String
  name             String
  company          String?
  role             String?
  email            String?
  linkedinUrl      String?
  relationshipType RelationshipType
  source           Source?
  notes            String?
  lastContactedAt  DateTime?
  followUpDate     DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications     ApplicationContact[]

  @@index([userId])
  @@index([company])
  @@index([followUpDate])
  @@index([userId, followUpDate])
}

model ApplicationContact {
  applicationId             String
  contactId                 String
  relationshipToApplication String?
  application               Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  contact                   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([applicationId, contactId])
}

model Document {
  id            String                 @id @default(cuid())
  userId        String
  name          String
  type          DocumentType
  url           String
  version       String?
  notes         String?
  tags          String[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  ApplicationDocument[]

  @@index([userId])
  @@index([updatedAt])
  @@index([userId, updatedAt])
}

model ApplicationDocument {
  applicationId String
  documentId    String
  usageType     String?
  notes         String?
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  document      Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([applicationId, documentId])
}

model TimelineEvent {
  id            String             @id @default(cuid())
  userId        String
  applicationId String
  type          TimelineEventType
  title         String
  description   String?
  occurredAt    DateTime
  attachmentUrl String?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model ActivityLog {
  id            String             @id @default(cuid())
  userId        String
  applicationId String?
  entityType    ActivityEntityType
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model Reminder {
  id            String        @id @default(cuid())
  userId        String
  applicationId String?
  interviewId   String?
  taskId        String?
  title         String
  remindAt      DateTime
  type          ReminderType
  completed     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  interview     Interview?    @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  task          Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([remindAt])
  @@index([completed])
  @@index([userId, remindAt])
  @@index([userId, completed])
  @@index([userId, remindAt, completed])
}

model UserSettings {
  id                    String           @id @default(cuid())
  userId                String           @unique
  university            String?
  major                 String?
  graduationYear        Int?
  targetRoles           String[]
  targetLocations       String[]
  defaultSeason         InternshipSeason?
  defaultYear           Int?
  defaultStatus         ApplicationStatusType @default(WISHLIST)
  defaultReminderMins   Int              @default(1440)
  customTags            String[]
  customRoleTypes       String[]
  customSources         String[]
  deadlineReminders     Boolean          @default(true)
  interviewReminders    Boolean          @default(true)
  followUpReminders     Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier  String
  token       String
  expires     DateTime

  @@id([identifier, token])
}
