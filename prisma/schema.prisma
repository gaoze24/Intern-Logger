// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatusType {
  WISHLIST
  RESEARCHING
  PREPARING
  DOCUMENTS_PENDING
  APPLIED
  SUBMITTED
  UNDER_REVIEW
  ONLINE_ASSESSMENT
  RECRUITER_SCREEN
  TECHNICAL_INTERVIEW
  BEHAVIORAL_INTERVIEW
  FINAL_ROUND
  INTERVIEW
  WAITLISTED
  OFFER
  ACCEPTED
  REJECTED
  DEFERRED
  WITHDRAWN
  ARCHIVED
  CUSTOM
}

enum ApplicationType {
  JOB
  UNIVERSITY
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
  UNKNOWN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  DREAM
}

enum Source {
  LINKEDIN
  COMPANY_WEBSITE
  REFERRAL
  CAREER_FAIR
  RECRUITER
  UNIVERSITY_PORTAL
  UNIVERSITY_WEBSITE
  COMMON_APP
  UCAS
  GRAD_PORTAL
  AGENT_CONSULTANT
  PROFESSOR
  ALUMNI
  EDUCATION_FAIR
  EMAIL
  OTHER
}

enum InternshipSeason {
  SUMMER
  WINTER
  SPRING
  FALL
  OFF_CYCLE
}

enum InterviewType {
  OA
  PHONE_SCREEN
  HR_INTERVIEW
  TECHNICAL_INTERVIEW
  BEHAVIORAL_INTERVIEW
  CASE_INTERVIEW
  FINAL_ROUND
  TAKE_HOME
  GROUP_INTERVIEW
  OTHER
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  CANCELED
}

enum DocumentType {
  RESUME
  COVER_LETTER
  TRANSCRIPT
  PORTFOLIO
  GITHUB
  WEBSITE
  WRITING_SAMPLE
  CERTIFICATE
  PERSONAL_STATEMENT
  STATEMENT_OF_PURPOSE
  RECOMMENDATION_LETTER
  TEST_SCORE
  RESEARCH_PROPOSAL
  PASSPORT
  FINANCIAL_DOCUMENT
  SCHOLARSHIP_ESSAY
  OTHER
}

enum RelationshipType {
  RECRUITER
  ALUMNI
  REFERRAL
  INTERVIEWER
  HIRING_MANAGER
  EMPLOYEE
  FRIEND
  ADMISSIONS_OFFICER
  PROFESSOR
  POTENTIAL_SUPERVISOR
  PROGRAM_COORDINATOR
  CURRENT_STUDENT
  RECOMMENDER
  AGENT_CONSULTANT
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderType {
  APPLICATION_DEADLINE
  OA_DEADLINE
  INTERVIEW
  FOLLOW_UP
  OFFER_DECISION
  SCHOLARSHIP_DEADLINE
  RECOMMENDATION_DEADLINE
  DECISION_DATE
  DEPOSIT_DEADLINE
  TASK_DUE
}

enum DegreeLevel {
  UNDERGRADUATE
  MASTERS
  PHD
  MBA
  EXCHANGE
  TRANSFER
  CERTIFICATE
  OTHER
}

enum IntakeTerm {
  FALL
  SPRING
  SUMMER
  WINTER
  ROLLING
  OTHER
}

enum ActivityEntityType {
  APPLICATION
  STATUS
  INTERVIEW
  TASK
  CONTACT
  DOCUMENT
  TIMELINE
  NOTE
  REMINDER
}

enum TimelineEventType {
  DISCOVERED
  PREPARATION_STARTED
  APPLIED
  OA_RECEIVED
  OA_SUBMITTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
  FOLLOW_UP_SENT
  STATUS_CHANGED
  NOTE_ADDED
}

model User {
  id             String              @id @default(cuid())
  name           String?
  email          String              @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  accounts       Account[]
  sessions       Session[]
  statuses       ApplicationStatus[]
  tags           Tag[]
  applications   Application[]
  interviews     Interview[]
  tasks          Task[]
  contacts       Contact[]
  documents      Document[]
  timelineEvents TimelineEvent[]
  activityLogs   ActivityLog[]
  reminders      Reminder[]
  settings       UserSettings?
}

model Application {
  id                          String                       @id @default(cuid())
  userId                      String
  applicationType             ApplicationType              @default(JOB)
  companyName                 String
  roleTitle                   String
  department                  String?
  location                    String?
  country                     String?
  workMode                    WorkMode                     @default(UNKNOWN)
  status                      ApplicationStatusType        @default(WISHLIST)
  customStatusId              String?
  priority                    Priority                     @default(MEDIUM)
  source                      Source                       @default(OTHER)
  applicationUrl              String?
  jobPostingUrl               String?
  deadline                    DateTime?
  appliedDate                 DateTime?
  discoveredDate              DateTime?
  season                      InternshipSeason?
  applicationYear             Int?
  compensation                String?
  visaSponsorship             Boolean?
  referralUsed                Boolean                      @default(false)
  jobDescription              String?
  notes                       String?
  archived                    Boolean                      @default(false)
  archivedAt                  DateTime?
  previousStatusBeforeArchive ApplicationStatusType?
  deletedAt                   DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customStatus                ApplicationStatus?           @relation(fields: [customStatusId], references: [id], onDelete: SetNull)
  jobDetail                   JobApplicationDetail?
  universityDetail            UniversityApplicationDetail?
  interviews                  Interview[]
  tasks                       Task[]
  timelineEvents              TimelineEvent[]
  activities                  ActivityLog[]
  reminders                   Reminder[]
  tags                        ApplicationTag[]
  contacts                    ApplicationContact[]
  documents                   ApplicationDocument[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
  @@index([appliedDate])
  @@index([archived])
  @@index([deletedAt])
  @@index([userId, archived, status])
  @@index([userId, status])
  @@index([userId, archived])
  @@index([userId, deletedAt])
  @@index([userId, archived, deletedAt])
  @@index([userId, companyName, roleTitle])
  @@index([userId, companyName])
  @@index([userId, roleTitle])
  @@index([userId, deadline])
  @@index([userId, updatedAt])
  @@index([userId, applicationType])
  @@index([userId, applicationType, archived])
  @@index([userId, applicationType, status])
  @@index([userId, applicationType, deadline])
  @@index([userId, applicationType, deletedAt])
  @@index([updatedAt])
}

model JobApplicationDetail {
  id              String            @id @default(cuid())
  applicationId   String            @unique
  application     Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  companyName     String
  roleTitle       String
  department      String?
  workMode        WorkMode          @default(UNKNOWN)
  season          InternshipSeason?
  applicationYear Int?
  compensation    String?
  visaSponsorship Boolean?
  referralUsed    Boolean           @default(false)
  jobPostingUrl   String?
  applicationUrl  String?
  jobDescription  String?
}

model UniversityApplicationDetail {
  id                              String       @id @default(cuid())
  applicationId                   String       @unique
  application                     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  institutionName                 String
  programName                     String
  degreeLevel                     DegreeLevel?
  facultyOrDepartment             String?
  applicationRound                String?
  intakeTerm                      IntakeTerm?
  intakeYear                      Int?
  campus                          String?
  programUrl                      String?
  applicationPortalUrl            String?
  tuitionEstimate                 String?
  scholarshipApplied              Boolean      @default(false)
  fundingStatus                   String?
  testRequirementStatus           String?
  recommendationRequirementStatus String?
  statementPrompt                 String?
}

model ApplicationStatus {
  id           String        @id @default(cuid())
  userId       String
  name         String
  color        String        @default("#64748b")
  order        Int
  isFinal      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([userId, name])
  @@index([userId, order])
}

model Tag {
  id           String           @id @default(cuid())
  userId       String
  name         String
  color        String           @default("#a855f7")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationTag[]

  @@unique([userId, name])
}

model ApplicationTag {
  applicationId String
  tagId         String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([applicationId, tagId])
}

model Interview {
  id               String           @id @default(cuid())
  userId           String
  applicationId    String
  title            String
  type             InterviewType
  scheduledAt      DateTime
  durationMinutes  Int?
  location         String?
  meetingLink      String?
  interviewerName  String?
  interviewerEmail String?
  preparationNotes String?
  questionsAsked   String?
  reflection       String?
  outcome          InterviewOutcome @default(PENDING)
  followUpRequired Boolean          @default(false)
  thankYouSent     Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  application      Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reminders        Reminder[]

  @@index([userId])
  @@index([applicationId])
  @@index([scheduledAt])
  @@index([userId, scheduledAt])
  @@index([userId, applicationId, scheduledAt])
}

model Task {
  id              String          @id @default(cuid())
  userId          String
  applicationId   String?
  applicationType ApplicationType @default(JOB)
  title           String
  description     String?
  dueDate         DateTime?
  priority        TaskPriority    @default(MEDIUM)
  completed       Boolean         @default(false)
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  reminders       Reminder[]

  @@index([userId])
  @@index([applicationId])
  @@index([dueDate])
  @@index([completed])
  @@index([userId, dueDate])
  @@index([userId, completed])
  @@index([userId, completed, dueDate])
  @@index([userId, applicationId, dueDate])
  @@index([userId, applicationId, completed])
  @@index([userId, applicationType])
  @@index([userId, applicationType, completed])
  @@index([userId, applicationType, dueDate])
}

model Contact {
  id               String               @id @default(cuid())
  userId           String
  applicationType  ApplicationType      @default(JOB)
  name             String
  company          String?
  role             String?
  email            String?
  linkedinUrl      String?
  relationshipType RelationshipType
  source           Source?
  notes            String?
  lastContactedAt  DateTime?
  followUpDate     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications     ApplicationContact[]

  @@index([userId])
  @@index([company])
  @@index([followUpDate])
  @@index([userId, company])
  @@index([userId, followUpDate])
  @@index([userId, applicationType])
  @@index([userId, applicationType, followUpDate])
}

model ApplicationContact {
  applicationId             String
  contactId                 String
  relationshipToApplication String?
  application               Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  contact                   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([applicationId, contactId])
}

model Document {
  id              String                @id @default(cuid())
  userId          String
  applicationType ApplicationType       @default(JOB)
  name            String
  type            DocumentType
  url             String
  version         String?
  notes           String?
  tags            String[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    ApplicationDocument[]

  @@index([userId])
  @@index([userId, type])
  @@index([updatedAt])
  @@index([userId, updatedAt])
  @@index([userId, applicationType])
  @@index([userId, applicationType, type])
  @@index([userId, applicationType, updatedAt])
}

model ApplicationDocument {
  applicationId String
  documentId    String
  usageType     String?
  notes         String?
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([applicationId, documentId])
}

model TimelineEvent {
  id            String            @id @default(cuid())
  userId        String
  applicationId String
  type          TimelineEventType
  title         String
  description   String?
  occurredAt    DateTime
  attachmentUrl String?
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([userId, applicationId, occurredAt])
}

model ActivityLog {
  id            String             @id @default(cuid())
  userId        String
  applicationId String?
  entityType    ActivityEntityType
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, applicationId, createdAt])
}

model Reminder {
  id              String          @id @default(cuid())
  userId          String
  applicationId   String?
  applicationType ApplicationType @default(JOB)
  interviewId     String?
  taskId          String?
  title           String
  remindAt        DateTime
  type            ReminderType
  completed       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  interview       Interview?      @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([remindAt])
  @@index([completed])
  @@index([userId, remindAt])
  @@index([userId, completed])
  @@index([userId, remindAt, completed])
  @@index([userId, applicationType])
  @@index([userId, applicationType, remindAt])
  @@index([userId, applicationType, completed])
}

model UserSettings {
  id                  String                @id @default(cuid())
  userId              String                @unique
  applicationMode     ApplicationType       @default(JOB)
  university          String?
  major               String?
  graduationYear      Int?
  targetRoles         String[]
  targetLocations     String[]
  defaultSeason       InternshipSeason?
  defaultYear         Int?
  defaultStatus       ApplicationStatusType @default(WISHLIST)
  defaultReminderMins Int                   @default(1440)
  customTags          String[]
  customRoleTypes     String[]
  customSources       String[]
  deadlineReminders   Boolean               @default(true)
  interviewReminders  Boolean               @default(true)
  followUpReminders   Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
